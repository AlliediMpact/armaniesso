# Paystack (Use test keys for development, production keys for production)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# App URL used for redirects/callbacks
NEXT_PUBLIC_APP_URL=https://www.armaniesso.co.za

# Firebase config (client-facing values must use NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:xxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Server-side alias if needed later
FIREBASE_PROJECT_ID=your-project-id

# Firebase Admin SDK (required for production token verification)
# This is sensitive! Only set in Vercel Environment Variables, never commit
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# Enable Firestore for production order storage
FIREBASE_USE_FIRESTORE_ORDERS=true

# Comma-separated admin emails for dashboard access control
NEXT_PUBLIC_ADMIN_EMAILS=admin1@armaniesso.co.za,admin2@armaniesso.co.za
ADMIN_EMAILS=admin@armaniesso.co.za

# SMTP (Nodemailer) - For transactional emails
SMTP_HOST=mail.example.com
SMTP_PORT=465
SMTP_USER=noreply@armaniesso.co.za
SMTP_PASS=your-secure-smtp-password
EMAIL_FROM=noreply@armaniesso.co.za

# Paystack callback override (optional, defaults to public app URL)
# PAYSTACK_CALLBACK_URL=https://www.armaniesso.co.za/api/paystack/webhook
